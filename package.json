{
  "name": "workpad",
  "productName": "Workpad",
  "version": "0.2.1",
  "description": "오피스용 로컬 플로팅 카드 메모 도구 — 메모장을 대체하는 오프라인 워크벤치 (offline floating-card workpad for office teams)",
  "license": "MIT",
  "author": "Hai-kkum",
  "private": true,
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.workpad.app",
    "productName": "Workpad",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/brand/**/*",
      "workpad.config.json"
    ],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "assets/brand/workpad-app-icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Workpad",
      "runAfterFinish": true,
      "artifactName": "Workpad-${version}-setup.${ext}"
    },
    "portable": {
      "artifactName": "Workpad-${version}-portable.exe"
    }
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3"
  }
}
